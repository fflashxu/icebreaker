PORT=3100
NODE_ENV=development
FRONTEND_URL=http://localhost:5200

# PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/icebreaker

# Auth
JWT_SECRET=change-this-to-a-random-32-char-string

# Initial admin account (created on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YourAdminPassword123

# DashScope API Key — get yours at https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-key-here
